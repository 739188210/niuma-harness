# Keep repository text files consistent across macOS, Linux, and Windows.
* text=auto eol=lf

# Windows command scripts require CRLF for broad compatibility.
*.bat text eol=crlf
*.cmd text eol=crlf

# Never modify binary files.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.gz binary
